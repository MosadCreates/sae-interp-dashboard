{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Feature Case Studies — Interactive Analysis\n",
    "\n",
    "This notebook loads a trained Sparse Autoencoder and interactively explores learned features.\n",
    "\n",
    "**Requirements**: A trained SAE checkpoint at `models/sae_medium/sae_final.pt` (or wherever your model is saved)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, \"..\")  # add project root to path\n",
    "\n",
    "import torch\n",
    "import numpy as np\n",
    "from collections import Counter, defaultdict\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "from src.sae.model import SparseAutoencoder\n",
    "from src.model import ActivationExtractor\n",
    "from src.data.corpus import create_corpus_dataset\n",
    "\n",
    "%matplotlib inline\n",
    "sns.set_theme(style=\"darkgrid\")\n",
    "print(\"Imports OK\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Trained SAE\n",
    "\n",
    "Update the path below to point to your trained SAE checkpoint."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(f\"Using device: {device}\")\n",
    "\n",
    "# --- Load SAE ---\n",
    "checkpoint_path = \"../models/sae_medium/sae_final.pt\"\n",
    "checkpoint = torch.load(checkpoint_path, map_location=\"cpu\")\n",
    "\n",
    "sae_config = checkpoint.get(\"config\", {})\n",
    "d_model = sae_config.get(\"d_model\", 768)\n",
    "d_sae = sae_config.get(\"d_sae\", 6144)\n",
    "\n",
    "sae = SparseAutoencoder(d_model=d_model, d_sae=d_sae)\n",
    "sae.load_state_dict(checkpoint[\"model_state_dict\"])\n",
    "sae.to(device)\n",
    "sae.eval()\n",
    "\n",
    "print(f\"SAE loaded: {d_model} -> {d_sae}\")\n",
    "print(f\"Training loss: {checkpoint.get('loss', 'N/A'):.4f}\")\n",
    "print(f\"Explained variance: {checkpoint.get('explained_variance', 'N/A'):.4f}\")\n",
    "print(f\"L0 sparsity: {checkpoint.get('l0', 'N/A'):.1f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Extract Top Activating Tokens\n",
    "\n",
    "Process a small subset of the corpus through GPT-2 + SAE to find top activating contexts per feature."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "extractor = ActivationExtractor(\n",
    "    model_name=\"gpt2\",\n",
    "    layer=8,\n",
    "    hook_point=\"residual_post\",\n",
    "    device=device,\n",
    ")\n",
    "\n",
    "dataset = create_corpus_dataset(\n",
    "    extractor.tokenizer,\n",
    "    context_length=128,\n",
    "    max_tokens=100_000,\n",
    ")\n",
    "dataloader = torch.utils.data.DataLoader(\n",
    "    dataset, batch_size=8, num_workers=2\n",
    ")\n",
    "\n",
    "print(f\"Corpus dataset ready\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "top_k = 20\n",
    "feature_top = defaultdict(list)\n",
    "\n",
    "with torch.no_grad():\n",
    "    for batch_idx, batch in enumerate(dataloader):\n",
    "        if batch_idx >= 100:\n",
    "            break\n",
    "\n",
    "        acts = extractor(batch.to(device))\n",
    "        b, s, d = acts.shape\n",
    "        acts_flat = acts.reshape(-1, d)\n",
    "\n",
    "        feat_acts = sae.encode(acts_flat)\n",
    "\n",
    "        for pos in range(b * s):\n",
    "            f_acts = feat_acts[pos].cpu().numpy()\n",
    "            seq_idx = pos % s\n",
    "            batch_idx_inner = pos // s\n",
    "\n",
    "            for fid in range(d_sae):\n",
    "                val = float(f_acts[fid])\n",
    "                if val > 3.0:\n",
    "                    ctx_start = max(0, seq_idx - 8)\n",
    "                    ctx_end = min(s, seq_idx + 9)\n",
    "                    ctx_ids = batch[batch_idx_inner, ctx_start:ctx_end].tolist()\n",
    "                    ctx_tokens = extractor.tokenizer.convert_ids_to_tokens(ctx_ids)\n",
    "\n",
    "                    entry = (val, ctx_tokens, seq_idx - ctx_start)\n",
    "                    heap = feature_top[fid]\n",
    "                    heap.append(entry)\n",
    "                    heap.sort(key=lambda x: -x[0])\n",
    "                    if len(heap) > top_k:\n",
    "                        heap.pop()\n",
    "\n",
    "print(f\"Collected top activations for {sum(1 for v in feature_top.values() if len(v) >= 5)} features\")\n",
    "extractor.remove_hooks()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Display Feature Summary\n",
    "\n",
    "Enter a feature ID to see its top activating contexts:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def show_feature(fid, n_contexts=10):\n",
    "    entries = feature_top.get(fid, [])\n",
    "    if not entries:\n",
    "        print(f\"Feature {fid}: no data\")\n",
    "        return\n",
    "\n",
    "    # Auto-label\n",
    "    center_tokens = []\n",
    "    for val, ctx_tokens, center in entries:\n",
    "        tok = ctx_tokens[center].replace(\"\\u0120\", \"\").replace(\"\\u010a\", \"\\\\n\")\n",
    "        center_tokens.append(tok)\n",
    "    counter = Counter(center_tokens)\n",
    "    label = counter.most_common(1)[0][0] if counter else \"?\"\n",
    "\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"Feature {fid}: '{label}' (frequency in {len(entries)} entries)\")\n",
    "    print(f\"{'='*60}\")\n",
    "\n",
    "    for i, (val, ctx_tokens, center) in enumerate(entries[:n_contexts]):\n",
    "        parts = []\n",
    "        for j, t in enumerate(ctx_tokens):\n",
    "            t_clean = t.replace(\"\\u0120\", \" \").replace(\"\\u010a\", \"\\\\n\")\n",
    "            if j == center:\n",
    "                parts.append(f\"**{t_clean}**\")\n",
    "            else:\n",
    "                parts.append(t_clean)\n",
    "        ctx_str = \"\".join(parts).strip()\n",
    "        print(f\"  [{val:.1f}] ...{ctx_str}...\")\n",
    "\n",
    "\n",
    "# Example: show feature 40\n",
    "show_feature(40)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Explore Features Interactively\n",
    "\n",
    "Run the cell below and enter a feature ID to explore:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def interactive_explore():\n",
    "    while True:\n",
    "        try:\n",
    "            fid = input(\"\\nEnter feature ID (or 'q' to quit): \")\n",
    "            if fid.lower() == 'q':\n",
    "                break\n",
    "            fid = int(fid)\n",
    "            show_feature(fid, n_contexts=15)\n",
    "        except ValueError:\n",
    "            print(\"Please enter a valid integer\")\n",
    "        except KeyboardInterrupt:\n",
    "            break\n",
    "\n",
    "# Uncomment to run:\n",
    "# interactive_explore()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Prompt Analysis\n",
    "\n",
    "Enter an arbitrary prompt and see which features activate:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def analyze_prompt(prompt, n_features=10):\n",
    "    from src.analysis.prompt_activations import get_prompt_activations\n",
    "    extractor2 = ActivationExtractor(device=device)\n",
    "    result = get_prompt_activations(prompt, extractor2, sae)\n",
    "    extractor2.remove_hooks()\n",
    "\n",
    "    print(f\"\\nPrompt: {prompt}\")\n",
    "    print(f\"Tokens: {result['tokens']}\")\n",
    "    print(f\"\\nTop features across prompt:\")\n",
    "    for f in result['top_features'][:n_features]:\n",
    "        print(f\"  Feature {f['feature_id']}: max activation = {f['max_activation']:.2f}\")\n",
    "\n",
    "    # Show which features activate on each token\n",
    "    print(f\"\\nPer-token feature activations:\")\n",
    "    for i, tok in enumerate(result['tokens']):\n",
    "        acts = result['per_token_features'][i][:3]\n",
    "        if acts:\n",
    "            act_str = \", \".join([f\"F{a['feature_id']}={a['value']:.1f}\" for a in acts])\n",
    "            print(f\"  {tok:15s} → {act_str}\")\n",
    "\n",
    "    return result\n",
    "\n",
    "\n",
    "# Example\n",
    "result = analyze_prompt(\n",
    "    \"Once upon a time, in a magical forest, there lived a little rabbit named Fluffy.\"\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Feature Geometry\n",
    "\n",
    "Examine the cosine similarity structure of the decoder:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.analysis.geometry import compute_geometry\n",
    "\n",
    "results = compute_geometry(sae, output_dir=\"../results\")\n",
    "\n",
    "sim = results['geometry']['pairwise_similarity']\n",
    "print(f\"Pairwise decoder similarity:\")\n",
    "print(f\"  Mean: {sim['mean']:.4f}\")\n",
    "print(f"  Std:  {sim['std']:.4f}\")\n",
    "print(f\"  Min:  {sim['min']:.4f}\")\n",
    "print(f\"  Max:  {sim['max']:.4f}\")\n",
    "\n",
    "norms = results['geometry']['decoder_norms']\n",
    "print(f\"\\nDecoder norms:\")\n",
    "print(f\"  Mean: {norms['mean']:.4f} (should be ~1.0)\")\n",
    "print(f\"  Min:  {norms['min']:.4f}\")\n",
    "print(f\"  Max:  {norms['max']:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot histogram of pairwise similarities\n",
    "hist = sim.get('histogram', [])\n",
    "if hist:\n",
    "    centers = [b['bin_center'] for b in hist]\n",
    "    counts = [b['count'] for b in hist]\n",
    "    plt.figure(figsize=(8, 4))\n",
    "    plt.bar(centers, counts, width=(centers[1]-centers[0]) if len(centers)>1 else 0.05, color='orange', alpha=0.7)\n",
    "    plt.xlabel('Cosine Similarity')\n",
    "    plt.ylabel('Count')\n",
    "    plt.title('Distribution of Pairwise Decoder Cosine Similarities')\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Feature Activation Heatmap Over a Prompt\n",
    "\n",
    "Visualise which tokens activate a selected feature:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.colors as mcolors\n",
    "\n",
    "def plot_feature_heatmap(prompt, feature_id):\n",
    "    extractor3 = ActivationExtractor(device=device)\n",
    "    result = get_prompt_activations(prompt, extractor3, sae)\n",
    "    extractor3.remove_hooks()\n",
    "\n",
    "    tokens = result['tokens']\n",
    "    activations = []\n",
    "    for t in result['per_token_features']:\n",
    "        val = next((a['value'] for a in t if a['feature_id'] == feature_id), 0)\n",
    "        activations.append(val)\n",
    "\n",
    "    max_val = max(activations) if activations else 1\n",
    "    if max_val == 0:\n",
    "        max_val = 1\n",
    "\n",
    "    # Create figure\n",
    "    fig, ax = plt.subplots(figsize=(max(12, len(tokens) * 0.5), 1.5))\n",
    "\n",
    "    norm = mcolors.Normalize(vmin=0, vmax=max_val)\n",
    "    cmap = plt.cm.Oranges\n",
    "\n",
    "    for i, (tok, val) in enumerate(zip(tokens, activations)):\n",
    "        color = cmap(norm(val))\n",
    "        ax.bar(i, 1, width=1, color=color, edgecolor='none', linewidth=0)\n",
    "        ax.text(i, 0.5, tok, ha='center', va='center', fontsize=8,\n",
    "                color='white' if val > max_val * 0.4 else 'gray',\n",
    "                rotation=90)\n",
    "\n",
    "    ax.set_xlim(-0.5, len(tokens) - 0.5)\n",
    "    ax.set_ylim(0, 1)\n",
    "    ax.axis('off')\n",
    "    ax.set_title(f'Feature {feature_id} activations over prompt', fontsize=10)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    return tokens, activations\n",
    "\n",
    "\n",
    "# Example\n",
    "prompt = \"Once upon a time in a land far away, there lived a wise old owl.\"\n",
    "plot_feature_heatmap(prompt, feature_id=40)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Search Features by Keyword\n",
    "\n",
    "Find features whose top tokens contain a keyword:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def keyword_search(keyword):\n",
    "    keyword = keyword.lower()\n",
    "    matches = []\n",
    "    for fid, entries in feature_top.items():\n",
    "        for val, ctx_tokens, center in entries:\n",
    "            center_tok = ctx_tokens[center].lower()\n",
    "            if keyword in center_tok:\n",
    "                matches.append((fid, val))\n",
    "                break\n",
    "    matches.sort(key=lambda x: -x[1])\n",
    "    return matches\n",
    "\n",
    "\n",
    "# Example: find features for \"time\"\n",
    "results = keyword_search(\"time\")\n",
    "print(f\"Features matching 'time':\")\n",
    "for fid, val in results[:10]:\n",
    "    print(f\"  Feature {fid}: max activation = {val:.1f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Summary Statistics\n",
    "\n",
    "Count alive vs dead features, sparsity distribution, etc."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "n_alive = sum(1 for v in feature_top.values() if len(v) >= 5)\n",
    "print(f\"Features with >= 5 activating contexts: {n_alive} / {d_sae}\")\n",
    "print(f\"Dead features (no activations found): {d_sae - n_alive}\")\n",
    "\n",
    "# Activation value distribution\n",
    "all_vals = []\n",
    "for entries in feature_top.values():\n",
    "    for val, _, _ in entries:\n",
    "        all_vals.append(val)\n",
    "\n",
    "if all_vals:\n",
    "    plt.figure(figsize=(8, 4))\n",
    "    plt.hist(all_vals, bins=50, color='orange', alpha=0.7)\n",
    "    plt.xlabel('Activation Value')\n",
    "    plt.ylabel('Count')\n",
    "    plt.title('Distribution of Top-K Activation Values')\n",
    "    plt.yscale('log')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "print(f\"\\nActivation statistics:\")\n",
    "print(f\"  Mean: {np.mean(all_vals):.2f}\")\n",
    "print(f\"  Median: {np.median(all_vals):.2f}\")\n",
    "print(f\"  Max: {max(all_vals):.2f}\")"
   ]
  },
